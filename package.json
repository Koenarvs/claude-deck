{
  "name": "claude-deck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI wrapper + observer dashboard for Claude Code sessions",
  "scripts": {
    "dev": "concurrently --names server,client --prefix-colors blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6",
    "@dnd-kit/sortable": "^8",
    "@dnd-kit/utilities": "^3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12",
    "cors": "^2.8.5",
    "express": "^5",
    "lucide-react": "^0.474",
    "node-cron": "^4",
    "node-pty": "^1.1.0",
    "pino": "^10",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "react-router": "^7",
    "react-window": "^2",
    "recharts": "^2",
    "remark-gfm": "^4.0.1",
    "uuid": "^11",
    "ws": "^8",
    "zod": "^3.23",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/better-sqlite3": "^7",
    "@types/cors": "^2",
    "@types/express": "^5",
    "@types/node": "^22",
    "@types/node-cron": "^3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1",
    "@types/uuid": "^10",
    "@types/ws": "^8",
    "@vitejs/plugin-react": "^4",
    "concurrently": "^9",
    "jsdom": "^27",
    "pino-pretty": "^13",
    "prettier": "^3",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5.5",
    "vite": "^6",
    "vitest": "^3"
  }
}
